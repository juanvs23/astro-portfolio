---
import Layout from '../../layouts/SectionLayout.astro';
import ExperienceSection from '../../components/sections/ExperienceSection.astro';
import { getTranslations, locales, type Locale } from '@/i18n';

export function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale },
  }));
}

const locale = Astro.params.locale as Locale;
const t = await getTranslations(locale);
const seoPages = t('seo.pages') as Record<string, string>;
const seoDescriptions = t('seo.descriptions') as Record<string, string>;
---

<Layout locale={locale} title={seoPages.experience} description={seoDescriptions.experience}>
  <ExperienceSection locale={locale} />
</Layout>
