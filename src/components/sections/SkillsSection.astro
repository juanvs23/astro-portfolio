---
import { getTranslations, type Locale } from '@/i18n';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import AsciiMarker from '../ui/AsciiMarker.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);

const skillCategories = t('skills.categories') as { title: string; skills: string[] }[];
---

<Section id="skills">
  <Badge variant="section-label" class="mb-sm">
    {t('skills.title')}
  </Badge>

  <div class="border-b border-hairline mb-xl"></div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-xl">
    {skillCategories.map((category) => (
      <div class="bg-canvas">
        <h3 class="text-heading-md font-bold text-ink mb-md">
          <AsciiMarker state="add" class="mr-xs inline" />
          {category.title}
        </h3>

        <ul class="space-y-xs">
          {category.skills.map((skill) => (
            <li class="text-body-md text-body py-xs border-b border-hairline">
              {skill}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Section>
