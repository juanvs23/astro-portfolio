---
import { getTranslations, type Locale } from '@/i18n';
import Badge from '../ui/Badge.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);
---

<section id="hero" class="bg-surface-dark text-on-dark min-h-[100dvh] max-h-[100dvh] relative overflow-hidden">
  <div id="three-selector" class="absolute inset-0 w-full h-full z-0">
    <canvas id="three-canvas" class="w-full h-full"></canvas>
  </div>

  <div class="relative z-10 flex flex-col justify-center h-full max-w-[960px] mx-auto px-lg py-xl w-full">
    <Badge variant="news" class="mb-lg">
      {t('hero.badge')}
    </Badge>

    <h1 class="text-[38px] font-bold leading-[1.5] mb-xl">
      {t('hero.title')}
    </h1>

    <p class="text-body-md text-on-dark-mute mb-xxl max-w-[640px]">
      {t('hero.description')}
    </p>
  </div>
</section>

<script>
  import { initThreeScene } from '../../lib/three-scene';

  const container = document.getElementById('three-selector');
  const canvas = document.getElementById('three-canvas');

  if (container && canvas) {
    initThreeScene(container, canvas);
  } else {
    console.warn('Three.js container not found');
  }
</script>
