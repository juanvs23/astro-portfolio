---
import { getTranslations, type Locale } from '@/i18n';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import Input from '../ui/Input.astro';
import Textarea from '../ui/Textarea.astro';
import Button from '../ui/Button.astro';
import AsciiMarker from '../ui/AsciiMarker.astro';
import { socialLinks } from '@/constants/social-links';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);
---

<Section id="contact">
  <Badge variant="section-label" class="mb-sm">
    {t('contactUs.title')}
  </Badge>

  <div class="border-b border-hairline mb-xl"></div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-xxl">
    <div>
      <h3 class="text-heading-md font-bold text-ink mb-md">
        <AsciiMarker state="add" class="mr-xs inline" />
        {t('contactUs.subtitle')}
      </h3>

      <p class="text-body-md text-body mb-xl">
        {t('contactUs.formTitle')}
      </p>

      <form id="contact-form" class="space-y-lg">
        <Input
          name="name"
          label={t('inputField.fullName')}
          required
        />

        <Input
          name="phone"
          label={t('inputField.phone')}
          type="tel"
        />

        <Input
          name="email"
          label={t('inputField.email')}
          type="email"
          required
        />

        <Input
          name="subject"
          label={t('inputField.subject')}
          required
        />

        <Textarea
          name="message"
          label={t('inputField.message')}
          rows={5}
          required
        />

        <Button type="submit" variant="primary" class="w-full">
          {t('inputField.send')}
        </Button>

        <div id="form-status" class="hidden text-body-md mt-lg"></div>
      </form>
    </div>

    <div>
      <h3 class="text-heading-md font-bold text-ink mb-md">
        <AsciiMarker state="add" class="mr-xs inline" />
        {t('social.title')}
      </h3>

      <div class="border-b border-hairline mb-xl"></div>

      <ul class="space-y-0">
        {socialLinks.map((link) => (
          <li class="py-lg border-b border-hairline">
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-body-strong text-ink no-underline hover:text-mute transition-colors flex items-center gap-sm"
            >
              <AsciiMarker state="add" class="inline" />
              {link.name}
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-xl">
        <h4 class="text-body-strong text-ink mb-sm">
          {t('contact.emailTitle')}
        </h4>
        <a
          href={`mailto:${t('contact.emailAddress')}`}
          class="text-body-md text-accent no-underline hover:text-accent-hover transition-colors"
        >
          {t('contact.emailAddress')}
        </a>
      </div>
    </div>
  </div>
</Section>

<script define:vars={{ formMessages: { sending: t('contact.form.sending'), success: t('contact.form.success'), error: t('contact.form.error'), networkError: t('contact.form.networkError') } }}>
  import { submitContactForm } from '@/lib/contact-form';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries()) as Record<string, string>;

    await submitContactForm(
      data as any,
      formMessages,
      (status) => {
        if (statusEl) {
          statusEl.classList.remove('hidden', 'text-success', 'text-danger', 'text-mute');
          statusEl.textContent = status.message;

          if (status.state === 'sending') {
            statusEl.classList.add('text-mute');
          } else if (status.state === 'success') {
            statusEl.classList.add('text-success');
            form?.reset();
          } else {
            statusEl.classList.add('text-danger');
          }
        }
      },
    );
  });
</script>
