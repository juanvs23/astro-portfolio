---
import { getTranslations, type Locale } from '@/i18n';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import Input from '../ui/Input.astro';
import Textarea from '../ui/Textarea.astro';
import Button from '../ui/Button.astro';
import AsciiMarker from '../ui/AsciiMarker.astro';
import { socialLinks } from '@/constants/social-links';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);
---

<Section id="contact">
  <h1 data-typewriter data-aos="fade-down" class="text-[30px] md:text-[35px] lg:text-[38px] font-bold mb-sm">
    {t('seo.h1.contact')}
  </h1>

  <div class="border-b border-hairline mb-xl"></div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-xxl">
    <div>
      <h3 class="text-heading-md font-bold text-ink mb-md">
        <AsciiMarker state="add" class="mr-xs inline" />
        {t('contactUs.subtitle')}
      </h3>

      <p class="text-body-md text-body mb-xl">
        {t('contactUs.formTitle')}
      </p>

      <form id="contact-form" class="space-y-lg">
        <Input
          name="name"
          label={t('inputField.fullName')}
          required
        />

        <Input
          name="phone"
          label={t('inputField.phone')}
          type="tel"
        />

        <Input
          name="email"
          label={t('inputField.email')}
          type="email"
          required
        />

        <Input
          name="subject"
          label={t('inputField.subject')}
          required
        />

        <Textarea
          name="message"
          label={t('inputField.message')}
          rows={5}
          required
        />

        <Button type="submit" variant="primary" class="w-full">
          {t('inputField.send')}
        </Button>

        <div id="form-status" class="hidden text-body-md mt-lg"></div>
      </form>
    </div>

    <div>
      <h3 class="text-heading-md font-bold text-ink mb-md">
        <AsciiMarker state="add" class="mr-xs inline" />
        {t('social.title')}
      </h3>

  <div class="border-b border-hairline mb-xl" data-aos="fade-up" data-aos-delay="100"></div>

      <ul class="space-y-0">
        {socialLinks.map((link) => (
          <li class="py-lg border-b border-hairline">
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-body-strong text-ink no-underline hover:text-mute transition-colors flex items-center gap-sm"
            >
              <AsciiMarker state="add" class="inline" />
              {link.name}
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-xl">
        <h4 class="text-body-strong text-ink mb-sm">
          {t('contact.emailTitle')}
        </h4>
        <a
          href={`https://wa.me/${t('contact.whatsappNumber')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-sm px-md h-[36px] rounded-sm bg-primary text-on-primary border border-hairline-strong text-body-md font-medium no-underline hover:bg-canvas hover:text-ink hover:border-ink transition-colors duration-150"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t('contact.emailAddress')}
        </a>
      </div>
    </div>
  </div>
</Section>

<script define:vars={{ formMessages: { sending: t('contact.form.sending'), success: t('contact.form.success'), error: t('contact.form.error'), networkError: t('contact.form.networkError') } }}>
  async function submitForm(data, messages, onStatusChange) {
    onStatusChange({ state: 'sending', message: messages.sending });
    try {
      var response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      var result = await response.json();
      if (response.ok) {
        onStatusChange({ state: 'success', message: messages.success });
      } else {
        onStatusChange({ state: 'error', message: result.error || messages.error });
      }
    } catch {
      onStatusChange({ state: 'error', message: messages.networkError });
    }
  }

  var form = document.getElementById('contact-form');
  var statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var formData = new FormData(form);
    var data = Object.fromEntries(formData.entries());
    await submitForm(data, formMessages, function(status) {
      if (statusEl) {
        statusEl.classList.remove('hidden', 'text-success', 'text-danger', 'text-mute');
        statusEl.textContent = status.message;
        if (status.state === 'sending') {
          statusEl.classList.add('text-mute');
        } else if (status.state === 'success') {
          statusEl.classList.add('text-success');
          form?.reset();
        } else {
          statusEl.classList.add('text-danger');
        }
      }
    });
  });
</script>
