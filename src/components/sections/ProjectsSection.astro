---

<Section id="projects">
  <h1
    data-typewriter
    data-aos="fade-down"
    class="text-[30px] md:text-[35px] lg:text-[38px] font-bold mb-sm"
  >
    {t("seo.h1.projects")}
  </h1>

  <div
    class="border-b border-hairline mb-xl"
    data-aos="fade-up"
    data-aos-delay="100"
  >
  </div>

  <p
    class="text-body-md text-body mb-xl"
    data-aos="fade-up"
    data-aos-delay="150"
  >
    {t("projects.subtitle")}
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-xl">
    {
      projects.map((project) => (
        <ProjectItem textButton={t("projects.button")} project={project} />
      ))
    }
  </div>
</Section>
