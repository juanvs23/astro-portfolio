---
import { getTranslations, type Locale } from '@/i18n';
import Section from '../ui/Section.astro';
import { Image } from 'astro:assets';
import aboutMeImg from '@/assets/img/aboutme.jpg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);

const skillsLink = t('about.skillsLink');
---

<Section id="about">
  <div class="grid grid-cols-1 md:grid-cols-[4fr_6fr] gap-xl items-start">
    <div class="w-full">
      <Image
        src={aboutMeImg}
        alt={t('about.title')}
        class="w-full rounded-sm"
        loading="eager"
        fetchpriority="high"
        widths={[320, 640, 960]}
        formats={['webp', 'jpeg']}
      />
    </div>

    <div>
      <h1 data-typewriter data-aos="fade-down" class="text-[30px] md:text-[35px] lg:text-[38px] font-bold mb-sm">
        {t('seo.h1.about')}
      </h1>

      <div class="border-b border-hairline mb-xl" data-aos="fade-up" data-aos-delay="100"></div>

      <div
        class="text-body-md text-body leading-[1.5] mb-xl"
        data-aos="fade-up"
        data-aos-delay="150"
        set:html={t('about.description')}
      ></div>

      <div data-aos="fade-up" data-aos-delay="250">
        <a
          href={`/${locale}/skills`}
          class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-surface-dark/80 border border-on-dark-mute/30 text-on-dark text-sm font-medium hover:scale-110 hover:bg-surface-dark transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          <span>{skillsLink}</span>
        </a>
      </div>
    </div>
  </div>
</Section>
