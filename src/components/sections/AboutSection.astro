---
import { getTranslations, type Locale } from '@/i18n';
import Section from '../ui/Section.astro';
import Badge from '../ui/Badge.astro';
import AsciiMarker from '../ui/AsciiMarker.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);

const skillsList = locale === 'es'
  ? [
      'JavaScript (React, Next.js, Node.js)',
      'PHP, WordPress (temas y plugins nativos)',
      'Python, Linux, administración de servidores',
      'APIs: PayPal, Stripe, Google Maps',
      'Docker, Git, despliegue en servidores Linux',
      'CSS moderno (Grid, Flexbox, Tailwind)',
    ]
  : [
      'JavaScript (React, Next.js, Node.js)',
      'PHP, WordPress (native themes and plugins)',
      'Python, Linux, server administration',
      'APIs: PayPal, Stripe, Google Maps',
      'Docker, Git, Linux server deployment',
      'Modern CSS (Grid, Flexbox, Tailwind)',
    ];
---

<Section id="about">
  <div class="grid grid-cols-1 md:grid-cols-[320px_1fr] gap-xl items-start">
    <div class="w-full">
      <img
        src="/img/aboutme.jpg"
        alt={t('about.title')}
        class="w-full rounded-sm"
        loading="lazy"
      />
    </div>

    <div>
      <Badge variant="section-label" class="mb-sm">
        {t('about.title')}
      </Badge>

      <div class="border-b border-hairline mb-xl"></div>

      <div
        class="text-body-md text-body leading-[1.5] mb-xl"
        set:html={t('about.description')}
      ></div>

      <h3 class="text-heading-md font-bold text-ink mb-md">
        <AsciiMarker state="add" class="mr-xs inline" />
        {t('about.skills')}
      </h3>

      <ul class="space-y-sm">
        {skillsList.map((skill) => (
          <li class="text-body-md text-body py-sm border-b border-hairline">
            <AsciiMarker state="add" class="mr-xs inline" />
            {skill}
          </li>
        ))}
      </ul>
    </div>
  </div>
</Section>
