---
import { getTranslations, getLocalizedPathname, type Locale } from '@/i18n';
import { navLinks } from '@/constants/nav-links';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = await getTranslations(locale);

const enPath = getLocalizedPathname(currentPath, 'en');
const esPath = getLocalizedPathname(currentPath, 'es');
---

<header class="fixed top-0 left-0 right-0 z-50 bg-canvas border-b border-hairline h-[56px]">
  <nav aria-label={t('navigation.main')} class="max-w-[1100px] mx-auto px-lg h-full flex items-center justify-between">
    <div class="w-[80px] md:w-auto"></div>

    <div class="hidden md:flex items-center gap-xl">
      {navLinks.map((link) => (
        <a
          href={`/${locale}${link.path}`}
          class="text-body-strong text-ink no-underline hover:text-mute transition-colors"
        >
          {t(link.key)}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-md">
      <ThemeToggle locale={locale} />

      <a
        href={locale === 'es' ? enPath : esPath}
        aria-label={locale === 'es' ? t('LocaleSwitcher.en') : t('LocaleSwitcher.es')}
        hreflang={locale === 'es' ? 'en' : 'es'}
        class="text-body-md text-mute no-underline hover:text-ink transition-colors"
      >
        {locale === 'es' ? t('common.langEn') : t('common.langEs')}
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden text-ink p-xs cursor-pointer"
        aria-label={t('menu.open')}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>
</header>
