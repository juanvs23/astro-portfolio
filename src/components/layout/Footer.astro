---
import { getTranslations, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = await getTranslations(locale);

const footerLinks = [
  { label: 'GitHub', href: 'https://github.com/juanvs23' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/juanvs23/' },
  { label: 'X', href: 'https://twitter.com/juanvs23' },
  { label: 'Facebook', href: 'https://www.facebook.com/juancarlos.avila.1420/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-hairline py-[32px]">
  <div class="max-w-[1100px] mx-auto px-lg">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-lg mb-xl">
      {footerLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-caption-md text-body no-underline hover:text-ink transition-colors text-center md:text-left"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-sm border-t border-hairline pt-lg">
      <span class="text-caption-md text-mute">
        {t('footer.copy')}{currentYear} {t('footer.develop')}Juan Carlos Ávila
      </span>

      <div class="flex items-center gap-lg">
        <a href={`/${locale}`} class="text-caption-md text-mute no-underline hover:text-ink transition-colors">
          Brand
        </a>
        <a href={`/${locale}`} class="text-caption-md text-mute no-underline hover:text-ink transition-colors">
          Privacy
        </a>
        <a href={`/${locale}`} class="text-caption-md text-mute no-underline hover:text-ink transition-colors">
          Terms
        </a>
        <span class="text-caption-md text-mute">
          {locale === 'es' ? 'Español' : 'English'}
        </span>
      </div>
    </div>
  </div>
</footer>
