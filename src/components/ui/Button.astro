---
interface Props {
  variant?: 'primary' | 'secondary' | 'tab';
  active?: boolean;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const {
  variant = 'primary',
  active = false,
  href,
  type = 'button',
  class: className = '',
} = Astro.props;

const baseClasses = 'font-mono text-body-md font-medium transition-colors duration-150 cursor-pointer';

const variantClasses = {
  primary: 'bg-primary text-on-primary rounded-sm px-xs h-[36px] hover:bg-ink-deep',
  secondary: 'bg-canvas text-ink border border-hairline-strong rounded-sm px-xs h-[36px] hover:bg-surface-soft',
  tab: active
    ? 'bg-transparent text-ink border-b-2 border-ash px-md py-xs'
    : 'bg-transparent text-mute px-md py-xs hover:text-ink',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
